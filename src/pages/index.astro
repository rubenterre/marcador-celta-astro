---
import Layout from "../layouts/Layout.astro";
import celtaLogo from "../assets/celta-escudo.svg";
---

<Layout>
  <div class="dashboard-shell">
    <header class="header">
      <div class="brand">
        <div class="brand-badge"></div>
        <div class="brand-text">
          <div class="brand-sub">Dashboard · Home</div>
          <div class="brand-main">RC Celta · Próximo partido</div>
        </div>
      </div>
      <div class="meta">
        <div class="season-pill">
          <span class="season-dot"></span>
          <span id="season-label">Temporada 2025-26 · LALIGA</span>
        </div>
        <div class="last-update" id="last-update">Actualizando datos…</div>
      </div>
    </header>

    <section class="match-card">
      <div class="match-card-header">
        <div class="match-title-block">
          <div class="match-title">Próximo partido</div>
          <div class="match-subtitle" id="match-subtitle">
            Buscando el próximo partido del RC Celta…
          </div>
        </div>
        <div id="live-pill-container">
          <!-- Se rellena dinámicamente: EN DIRECTO / Próximamente / Finalizado -->
        </div>
      </div>

      <div class="match-main" id="match-main" style="opacity: 0.25;">
        <div class="team home">
          <div class="team-logo-wrap">
            <img id="home-logo" class="team-logo" src="" alt="Home" />
          </div>
          <div>
            <div class="team-name" id="home-name">—</div>
            <div class="team-tag" id="home-tag" style="display:none">Celta</div>
          </div>
        </div>

        <div class="vs-block">
          <div class="vs-label">VS</div>
          <div class="match-kickoff" id="match-kickoff">—</div>
          <div class="match-extra-info" id="match-extra-info">—</div>
        </div>

        <div class="team away">
          <div class="team-logo-wrap">
            <img id="away-logo" class="team-logo" src="" alt="Away" />
          </div>
          <div>
            <div class="team-name" id="away-name">—</div>
            <div class="team-tag" id="away-tag" style="display:none">Celta</div>
          </div>
        </div>
      </div>

      <div class="match-footer">
        <div class="competition" id="competition">—</div>
        <div class="stadium" id="stadium">—</div>
      </div>

      <div class="loading" id="loading-msg">Conectando con API-Football…</div>
      <div class="status-message" id="error-msg" style="display:none;"></div>
    </section>
  </div>

  <script>
    // CONFIG – Football-Data.org
    const FD_API_KEY = import.meta.env.API_KEY_FOOTBALL_DATA;
    const FD_BASE_URL = "https://api.football-data.org/v4";
    const FD_TEAM_CELTA_ID = 558; // RC Celta de Vigo en football-data.org
    const FD_COMPETITION_LALIGA = "PD"; // La Liga (Primera División)
    const TIMEZONE = "Europe/Madrid";

    async function fetchNextFixtureFD() {
      const res = await fetch("/.netlify/functions/celta-next-match");
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(`Error HTTP ${res.status} ${data.error || ""}`.trim());
      }
      const data = await res.json();
      console.log(data);
      return data.match;
    }

    export const LALIGA_TEAM_LOGOS = {
      558: { name: "RC Celta de Vigo", logo: "/logos/celta.svg" },
      86: { name: "Real Madrid CF", logo: "/logos/real-madrid.svg" },
      81: { name: "FC Barcelona", logo: "/logos/barcelona.svg" },
      95: { name: "Valencia CF", logo: "/logos/valencia.svg" },
      78: { name: "Atlético de Madrid", logo: "/logos/atletico.svg" },
      559: { name: "Sevilla FC", logo: "/logos/sevilla.svg" },
      90: { name: "Real Betis", logo: "/logos/betis.svg" },
      92: { name: "Real Sociedad", logo: "/logos/real-sociedad.svg" },
      94: { name: "Villarreal CF", logo: "/logos/villarreal.svg" },
      77: { name: "Athletic Club", logo: "/logos/athletic.svg" },
      79: { name: "CA Osasuna", logo: "/logos/osasuna.svg" },
      87: { name: "Rayo Vallecano", logo: "/logos/rayo.svg" },
      263: { name: "Deportivo Alavés", logo: "/logos/alaves.svg" },
      80: { name: "RCD Espanyol", logo: "/logos/espanyol.svg" },
      285: { name: "Elche CF", logo: "/logos/elche.svg" },
      82: { name: "Getafe CF", logo: "/logos/getafe.svg" },
      89: { name: "RCD Mallorca", logo: "/logos/mallorca.svg" },
      88: { name: "Levante UD", logo: "/logos/levante.svg" },
      1048: { name: "Real Oviedo", logo: "/logos/oviedo.svg" },
      298: { name: "Girona FC", logo: "/logos/girona.svg" },
    };

    export function getTeamLogo(teamId) {
      return LALIGA_TEAM_LOGOS[teamId]?.logo || "/assets/logos/default.svg";
    }

    function formatDateTime(isoStr) {
      const dt = new Date(isoStr);
      const optsDate = { weekday: "short", day: "2-digit", month: "short" };
      const optsTime = { hour: "2-digit", minute: "2-digit" };
      const dateStr = dt.toLocaleDateString("es-ES", optsDate);
      const timeStr = dt.toLocaleTimeString("es-ES", optsTime);
      return { dateStr, timeStr };
    }

    function getLivePillFD(status) {
      // Status en football-data.org: SCHEDULED, IN_PLAY, PAUSED, FINISHED, etc. [web:22]
      if (status === "IN_PLAY" || status === "PAUSED") {
        return {
          html: `
          <div class="pill-live">
            <span class="pill-live-dot"></span>
            <span>En directo</span>
          </div>
        `,
          aria: "Partido en directo",
        };
      }
      if (status === "FINISHED") {
        return {
          html: `
          <div class="pill-finished">
            <span class="pill-finished-dot"></span>
            <span>Finalizado</span>
          </div>
        `,
          aria: "Partido finalizado",
        };
      }
      if (status === "SCHEDULED" || status === "TIMED") {
        return {
          html: `
          <div class="pill-soon">
            <span class="pill-soon-dot"></span>
            <span>Próximamente</span>
          </div>
        `,
          aria: "Partido pendiente de comenzar",
        };
      }
      return {
        html: `
        <div class="pill-soon">
          <span class="pill-soon-dot"></span>
          <span>${status}</span>
        </div>
      `,
        aria: "Estado del partido",
      };
    }

    function updateUIFD(match) {
      const matchMain = document.getElementById("match-main");
      const subtitle = document.getElementById("match-subtitle");
      const livePillContainer = document.getElementById("live-pill-container");
      const competition = document.getElementById("competition");
      const stadium = document.getElementById("stadium");
      const lastUpdate = document.getElementById("last-update");
      const loadingMsg = document.getElementById("loading-msg");

      const homeName = document.getElementById("home-name");
      const homeLogo = document.getElementById("home-logo");
      const awayName = document.getElementById("away-name");
      const awayLogo = document.getElementById("away-logo");
      const homeTag = document.getElementById("home-tag");
      const awayTag = document.getElementById("away-tag");
      const kickoff = document.getElementById("match-kickoff");
      const extraInfo = document.getElementById("match-extra-info");

      // football-data.org · estructura Match. [web:22]
      const homeTeam = match.homeTeam;
      const awayTeam = match.awayTeam;
      const comp = match.competition;
      const status = match.status;
      const utcDate = match.utcDate;
      const venueName = match.venue; // en algunos planes viene en match.venue / matchArea; si no, usamos ciudad del homeTeam. [web:22]

      const { dateStr, timeStr } = formatDateTime(utcDate);

      // Pill EN DIRECTO / estados
      const pill = getLivePillFD(status);
      livePillContainer.innerHTML = pill.html;
      livePillContainer.setAttribute("aria-label", pill.aria);

      // Título
      subtitle.textContent = match.matchday
        ? `Jornada ${match.matchday}`
        : comp.name;

      // Equipos
      homeName.textContent = homeTeam.name;
      awayName.textContent = awayTeam.name;

      homeLogo.src = getTeamLogo(homeTeam.id);
      awayLogo.src = getTeamLogo(awayTeam.id);

      // Logos: football-data.org devuelve crest en team/competition; para simplificar, dejamos placeholders SVG propios o URLs tuyas.
      // Aquí dejo atributos vacíos para que los rellenes tú con tus rutas locales, escudos oficiales, etc. [web:23]
      /*  homeLogo.src = ''; */
      homeLogo.alt = homeTeam.name;
      /*  awayLogo.src = ''; */
      awayLogo.alt = awayTeam.name;

      const isHomeCelta = homeTeam.id === FD_TEAM_CELTA_ID;
      const isAwayCelta = awayTeam.id === FD_TEAM_CELTA_ID;
      homeTag.style.display = isHomeCelta ? "inline-flex" : "none";
      awayTag.style.display = isAwayCelta ? "inline-flex" : "none";

      kickoff.textContent = `${dateStr} · ${timeStr}`;
      extraInfo.textContent = `Horario ${TIMEZONE}`;

      competition.textContent =
        comp.name + (match.matchday ? ` · Jornada ${match.matchday}` : "");

      stadium.textContent = venueName || "Estadio por confirmar";

      const now = new Date();
      const timeNow = now.toLocaleTimeString("es-ES", {
        hour: "2-digit",
        minute: "2-digit",
      });
      lastUpdate.textContent = `Última actualización · ${timeNow}`;

      matchMain.style.opacity = "1";
      loadingMsg.style.display = "none";
    }

    function showErrorFD(err) {
      const errorMsg = document.getElementById("error-msg");
      const loadingMsg = document.getElementById("loading-msg");
      const lastUpdate = document.getElementById("last-update");
      loadingMsg.style.display = "none";
      errorMsg.style.display = "block";
      errorMsg.textContent = `Error al cargar el próximo partido: ${err.message}`;
      lastUpdate.textContent = "Error de conexión con football-data.org";
    }

    async function initFD() {
      try {
        const match = await fetchNextFixtureFD();
        updateUIFD(match);
      } catch (err) {
        console.error(err);
        showErrorFD(err);
      }
    }

    // Primera carga
    initFD();

    // Opcional: refresco cada 5 minutos
    setInterval(initFD, 15 * 60 * 1000);
  </script>
</Layout>

<style define:vars={{ celtaLogo }}>
  .dashboard-shell {
    width: 100%;
    max-width: 520px;
    background: rgba(11, 23, 32, 0.92);
    border-radius: 24px;
    border: 1px solid var(--border-soft);
    backdrop-filter: blur(14px);
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.7),
      0 0 0 1px rgba(0, 0, 0, 0.6);
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  /* Cabecera */

  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand-badge {
    width: 32px;
    height: 48px;
    border-radius: 18px;
    background: linear-gradient(160deg, var(--celta-blue), #d3ecfb);
    position: relative;
    box-shadow:
      0 0 0 2px rgba(255, 255, 255, 0.65),
      0 10px 22px rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-badge::after {
    content: var(--celtaLogo);
    position: absolute;
    top: 0px;
    left: 2px;
    width: 12px;
    height: 12px;
    border-radius: 50% 50% 2px 2px;
  }

  .brand-badge-inner {
    width: 16px;
    height: 28px;
    border-radius: 10px;
    border: 2px solid rgba(11, 23, 32, 0.4);
    background: rgba(11, 23, 32, 0.3);
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .brand-sub {
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-soft);
  }

  .brand-main {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
  }

  .season-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px;
    border-radius: 999px;
    background: linear-gradient(
      135deg,
      rgba(138, 195, 238, 0.16),
      rgba(11, 23, 32, 0.9)
    );
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-soft);
    white-space: nowrap;
  }

  .season-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--live-green);
    box-shadow: 0 0 8px rgba(62, 233, 139, 0.6);
  }

  .last-update {
    font-size: 0.7rem;
    color: var(--text-soft);
  }

  /* Tarjeta próximo partido */

  .match-card {
    background: var(--bg-card);
    border-radius: 18px;
    border: 1px solid var(--border-soft);
    padding: 16px 16px 14px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .match-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .match-title-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .match-title {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-soft);
  }

  .match-subtitle {
    font-size: 0.78rem;
    color: var(--text-soft);
  }

  .pill-live {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: rgba(62, 233, 139, 0.12);
    color: var(--live-green);
    border: 1px solid rgba(62, 233, 139, 0.6);
  }

  .pill-live-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--live-green);
    box-shadow: 0 0 6px rgba(62, 233, 139, 0.8);
  }

  .pill-soon {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: rgba(138, 195, 238, 0.08);
    color: var(--celeste);
    border: 1px solid rgba(138, 195, 238, 0.5);
  }

  .pill-soon-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--celeste);
    box-shadow: 0 0 6px rgba(138, 195, 238, 0.8);
  }

  .pill-finished {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: rgba(167, 183, 199, 0.1);
    color: var(--text-soft);
    border: 1px solid rgba(167, 183, 199, 0.5);
  }

  .pill-finished-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--text-soft);
  }

  .match-main {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 14px;
  }

  .team {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .team.away {
    flex-direction: row-reverse;
    text-align: right;
  }

  .team-logo-wrap {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background: radial-gradient(
      circle at 30% 20%,
      #ffffff 0,
      #c8d9eb 38%,
      #446583 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 0 0 2px rgba(255, 255, 255, 0.16),
      0 10px 20px rgba(0, 0, 0, 0.7);
    overflow: hidden;
  }

  .team-logo {
    width: 32px;
    height: 32px;
    object-fit: contain;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.8));
  }

  .team-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-main);
  }

  .team-tag {
    margin-top: 2px;
    display: inline-flex;
    align-items: center;
    padding: 2px 7px;
    border-radius: 999px;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid rgba(138, 195, 238, 0.7);
    color: var(--celeste);
    background: rgba(138, 195, 238, 0.08);
  }

  .vs-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .vs-label {
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-soft);
  }

  .match-kickoff {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--celeste);
  }

  .match-extra-info {
    margin-top: 2px;
    font-size: 0.72rem;
    color: var(--text-soft);
  }

  .match-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-top: 2px;
  }

  .competition {
    font-size: 0.8rem;
    color: var(--text-soft);
  }

  .stadium {
    font-size: 0.78rem;
    color: var(--text-soft);
    text-align: right;
  }

  /* Estados */

  .status-message {
    font-size: 0.8rem;
    color: var(--alert);
    margin-top: 4px;
  }

  .loading {
    font-size: 0.82rem;
    color: var(--text-soft);
    margin-top: 4px;
  }

  @media (max-width: 480px) {
    .dashboard-shell {
      padding: 14px 14px 16px;
    }
    .header {
      flex-direction: column;
      align-items: flex-start;
    }
    .meta {
      align-items: flex-start;
    }
    .match-main {
      grid-template-columns: 1fr;
    }
    .team.away {
      flex-direction: row;
      text-align: left;
    }
    .vs-block {
      order: -1;
    }
    .match-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
